# Forge — environment contract (copy to .env.local; none required for the mock prototype)
# These wire M1 (live auth + data) and the AI/billing seams. The app runs fully on
# mock data with all of these unset.

# --- Supabase (auth, Postgres, storage, realtime) --------------------------
# Create a project at https://supabase.com, run supabase/migrations/0001_forge_init.sql,
# then paste the values from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (Edge Functions / route handlers). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI Coach (server-only; called from a Supabase Edge Function / route handler) ---
# The key must never reach the browser. Model: claude-opus-4-8.
ANTHROPIC_API_KEY=

# --- Billing (Stripe) ------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs for the tiers (Forge Pro / Forge Elite)
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# --- App ------------------------------------------------------------------
# Base URL the typed client SDK targets (lets a native client reuse the same API).
NEXT_PUBLIC_APP_URL=http://localhost:3000
